# BIM Nexus environment example.
# Django does not auto-load this file. Copy values into your shell, service,
# or deployment environment before starting the server.

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false

# Optional local Vite dev server. Leave empty for production-like built assets.
BIM_VITE_DEV_SERVER=

# Email setup for password setup links. Console backend is acceptable for local tests.
BIM_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
BIM_EMAIL_HOST=
BIM_EMAIL_PORT=587
BIM_EMAIL_USE_TLS=true
BIM_EMAIL_HOST_USER=
BIM_EMAIL_HOST_PASSWORD=
BIM_DEFAULT_FROM_EMAIL=BIM Nexus <noreply@bimpos.com>

# Login-page account access requests. Defaults to this address if unset.
BIM_ADMIN_EMAIL=jad.alasmar@bimpos.com
